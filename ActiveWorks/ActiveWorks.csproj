  <PropertyGroup>
    <UpdateHubOutputDir>..\UpdateHub\bin\$(Configuration)\</UpdateHubOutputDir>
    <UpdaterOutputDir>..\UpdateHub.Updater\bin\$(Configuration)\</UpdaterOutputDir>
    <SystemValueTupleDll>..\packages\System.ValueTuple.4.6.2\lib\net47\System.ValueTuple.dll</SystemValueTupleDll>
  </PropertyGroup>

  <PropertyGroup Condition="'$(TargetFramework)' == 'net10.0-windows'">
    <UpdateHubOutputDir>..\UpdateHub\bin\$(Configuration)\net10.0\</UpdateHubOutputDir>
    <UpdaterOutputDir>..\UpdateHub.Updater\bin\$(Configuration)\net10.0-windows\</UpdaterOutputDir>
  </PropertyGroup>

  <Target Name="AfterBuild">
    <Copy SourceFiles="$(UpdateHubOutputDir)UpdateHub.dll" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" Condition="Exists('$(UpdateHubOutputDir)UpdateHub.dll')" />
    <Copy SourceFiles="$(UpdateHubOutputDir)UpdateHub.pdb" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" Condition="Exists('$(UpdateHubOutputDir)UpdateHub.pdb')" />
    <Copy SourceFiles="$(UpdaterOutputDir)Updater.exe" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" Condition="Exists('$(UpdaterOutputDir)Updater.exe')" />
    <Copy SourceFiles="$(UpdaterOutputDir)Updater.pdb" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" Condition="Exists('$(UpdaterOutputDir)Updater.pdb')" />
    <Copy SourceFiles="$(SystemValueTupleDll)" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" Condition="Exists('$(SystemValueTupleDll)')" />
    <RemoveDir Directories="&#xA;      $(OutDir)arm;&#xA;      $(OutDir)arm64;&#xA;      $(OutDir)loongarch64;&#xA;      $(OutDir)musl-arm;&#xA;      $(OutDir)musl-arm64;&#xA;      $(OutDir)musl-loongarch64;&#xA;      $(OutDir)musl-riscv64;&#xA;      $(OutDir)musl-x64;&#xA;      $(OutDir)riscv64;&#xA;      $(OutDir)uk-UA;&#xA;      $(OutDir)x64;&#xA;      $(OutDir)x86" />
  </Target>

  <Target Name="CopyRuntimeFacades" AfterTargets="Build">
    <Copy SourceFiles="$(SystemValueTupleDll)" DestinationFolder="$(TargetDir)" SkipUnchangedFiles="true" Condition="Exists('$(SystemValueTupleDll)' ) and '$(TargetDir)' != ''" />
  </Target>

  <Target Name="RemoveNonWindowsRuntimeFolders" AfterTargets="Build" Condition="Exists('$(OutDir)runtimes')">
    <RemoveDir Directories="&#xA;      $(OutDir)runtimes\android-arm;&#xA;      $(OutDir)runtimes\android-arm64;&#xA;      $(OutDir)runtimes\android-x64;&#xA;      $(OutDir)runtimes\android-x86;&#xA;      $(OutDir)runtimes\ios-arm;&#xA;      $(OutDir)runtimes\ios-arm64;&#xA;      $(OutDir)runtimes\ios-armv7s;&#xA;      $(OutDir)runtimes\iossimulator-arm64;&#xA;      $(OutDir)runtimes\iossimulator-x64;&#xA;      $(OutDir)runtimes\linux;&#xA;      $(OutDir)runtimes\linux-arm;&#xA;      $(OutDir)runtimes\linux-arm64;&#xA;      $(OutDir)runtimes\linux-loongarch64;&#xA;      $(OutDir)runtimes\linux-musl-arm;&#xA;      $(OutDir)runtimes\linux-musl-arm64;&#xA;      $(OutDir)runtimes\linux-musl-loongarch64;&#xA;      $(OutDir)runtimes\linux-musl-riscv64;&#xA;      $(OutDir)runtimes\linux-musl-x64;&#xA;      $(OutDir)runtimes\linux-riscv64;&#xA;      $(OutDir)runtimes\linux-x64;&#xA;      $(OutDir)runtimes\linux-x86;&#xA;      $(OutDir)runtimes\maccatalyst-arm64;&#xA;      $(OutDir)runtimes\maccatalyst-x64;&#xA;      $(OutDir)runtimes\osx;&#xA;      $(OutDir)runtimes\osx-arm64;&#xA;      $(OutDir)runtimes\osx-x64;&#xA;      $(OutDir)runtimes\tvos-arm64;&#xA;      $(OutDir)runtimes\tvossimulator-x64" />
  </Target>
</Project>
