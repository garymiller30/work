<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <OutputType>Library</OutputType>
    <RootNamespace>PluginRabbitMq</RootNamespace>
    <AssemblyName>PluginRabbitMq</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <GenerateSatelliteAssembliesForCore>true</GenerateSatelliteAssembliesForCore>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Version="7.8.0" Include="EasyNetQ" />
    <PackageReference Version="13.0.4" Include="Newtonsoft.Json" />
    <PackageReference Version="6.8.1" Include="RabbitMQ.Client" />
    <PackageReference Version="4.6.0" Include="System.Buffers" />
    <PackageReference Version="4.6.0" Include="System.Memory" />
    <PackageReference Version="4.6.0" Include="System.Numerics.Vectors" />
    <PackageReference Version="6.1.0" Include="System.Runtime.CompilerServices.Unsafe" />
    <PackageReference Version="8.0.0" Include="System.Threading.Channels" />
    <PackageReference Version="4.5.4" Include="System.Threading.Tasks.Extensions" />
    <PackageReference Version="10.0.5" Include="System.Resources.Extensions" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="Logger">
      <HintPath>..\Logger\bin\$(Configuration)\Logger.dll</HintPath>
    </Reference>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Interfaces\Interfaces.csproj" />
    <ProjectReference Include="..\Logger\Logger.csproj" />
  </ItemGroup>
</Project>