@page "/"
@attribute [Authorize]
@rendermode InteractiveServer
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject WebAccessSettingsStore SettingsStore
@inject MongoProfileDataService MongoProfileDataService

<PageTitle>Роботи</PageTitle>

<div class="page-header">
    <div>
        <h1>Список робіт (@_jobs.Count)</h1>
    </div>
    <button class="primary-action" @onclick="LoadAsync" disabled="@_isLoading">Оновити</button>
</div>

@if (!string.IsNullOrWhiteSpace(_loadError))
{
    <div class="alert-panel error-panel">@_loadError</div>
}
else if (_currentUser is not null && !_currentUser.CanAccessJobsPage)
{
    <div class="empty-state">
        <h2>Доступ вимкнено</h2>
        <p>Адміністратор ще не надав цьому користувачу доступ до сторінки робіт.</p>
    </div>
}
else if (_isLoading)
{
    <div class="empty-state">
        <h2>Завантаження</h2>
        <p>Отримую список замовлень і тексти статусів…</p>
    </div>
}
else
{
    

    @if (_jobs.Count == 0)
    {
        <div class="empty-state">
            <h2>Немає робіт для показу</h2>
            <p>Перевірте список статусів у налаштуваннях адміністратора або параметри Mongo-профілю.</p>
        </div>
    }
    else
    {
        <div class="table-shell">
            <table class="jobs-table">
                <thead>
                    <tr>
                        <th>Дата</th>
                        <th>Статус</th>
                        <th>Номер</th>
                        <th>Замовник</th>
                        <th>Опис</th>
                        @if (_currentUser?.PayProcesses != null && _currentUser.PayProcesses.Any())
                        {
                            <th class="price">Вартість, грн</th>
                        }
                        
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in _jobs)
                    {
                        <tr>
                            <td>@job.Date.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            <td>
                                <span class="status-pill">@job.StatusText</span>
                            </td>
                            <td class="mono">@job.Number</td>
                            <td>@job.Customer</td>
                            <td>@job.Description</td>
                            @if (_currentUser?.PayProcesses != null && _currentUser.PayProcesses.Any())
                            {
                                <td class="mono price">@job.Price</td>
                            }
                            
                        </tr>
                    }
                    @if(_currentUser?.PayProcesses != null && _currentUser.PayProcesses.Any())
                    {
                         <tr>
                             <td colspan="6" class=" mono price">
                                <strong>@_totalPrice</strong>
                            </td>
                         </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    private bool _isLoading = true;
    private string? _loadError;
    private WebUserDefinition? _currentUser;
    private WebProfileDefinition? _profile;
    private List<JobListItemViewModel> _jobs = new();
    private decimal _totalPrice = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var username = authState.User.Identity?.Name;
            _currentUser = await SettingsStore.FindUserAsync(username);

            if (_currentUser is null)
            {
                _loadError = "Користувач не знайдений у конфігурації веб-порталу.";
                _jobs.Clear();
                return;
            }

            if (!_currentUser.CanAccessJobsPage)
            {
                _jobs.Clear();
                return;
            }

            _profile = await SettingsStore.FindProfileAsync(_currentUser.ProfileKey);
            if (_profile is null)
            {
                _loadError = $"Для користувача '{_currentUser.Username}' не знайдено профіль '{_currentUser.ProfileKey}'.";
                _jobs.Clear();
                return;
            }

            _jobs = (await MongoProfileDataService.GetJobsAsync(_profile, _currentUser.VisibleStatusCodes,_currentUser.PayProcesses))
                .ToList();
            _totalPrice = 0;
            if (_jobs.Count > 0)
                _totalPrice = _jobs.Sum(j => j.Price);
        }
        catch (Exception ex)
        {
            _jobs.Clear();
            _loadError = $"Не вдалося завантажити роботи: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}
