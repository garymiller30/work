@page "/"
@attribute [Authorize]
@rendermode InteractiveServer
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject WebAccessSettingsStore SettingsStore
@inject MongoProfileDataService MongoProfileDataService

<PageTitle>Роботи</PageTitle>

<div class="page-header">
    <div>
        <h1>@PageTitleText</h1>
        @if (!string.IsNullOrWhiteSpace(PageSubtitleText))
        {
            <p class="page-subtitle">@PageSubtitleText</p>
        }
    </div>
    <div class="header-actions">
        @if (CanShowPriceColumn)
        {
            <div class="cart-summary">
                <button class="cart-button" @onclick="OpenCart" title="Відкрити кошик">
                    <span class="cart-icon" aria-hidden="true">🛒</span>
                    <span>Кошик</span>
                    @if (CartCount > 0)
                    {
                        <span class="cart-count">@CartCount</span>
                    }
                </button>
                <span class="cart-total">Сума: @CartTotalPrice грн</span>
            </div>
        }
        <button class="primary-action" @onclick="LoadAsync" disabled="@_isLoading">Оновити</button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_loadError))
{
    <div class="alert-panel error-panel">@_loadError</div>
}
else if (!IsAdminViewer && _currentUser is not null && !_currentUser.CanAccessJobsPage)
{
    <div class="empty-state">
        <h2>Доступ вимкнено</h2>
        <p>Адміністратор ще не надав цьому користувачу доступ до сторінки робіт.</p>
    </div>
}
else if (IsAdminViewer && _currentUser is null)
{
    <div class="empty-state">
        <h2>Виберіть користувача</h2>
        <p>У лівій панелі доступний список користувачів. Натисніть на потрібного, щоб побачити його роботи.</p>
    </div>
}
else if (_isLoading)
{
    <div class="empty-state">
        <h2>Завантаження</h2>
        <p>Отримую список замовлень і тексти статусів…</p>
    </div>
}
else
{


    @if (_jobs.Count == 0)
    {
        <div class="empty-state">
            <h2>Немає робіт для показу</h2>
            <p>Перевірте список статусів у налаштуваннях адміністратора або параметри Mongo-профілю.</p>
        </div>
    }
    else
    {
        <div class="table-shell">
            <table class="jobs-table">
                <thead>
                    <tr>
                        <th>Дата</th>
                        <th>Статус</th>
                        <th>Номер</th>
                        <th>Замовник</th>
                        <th class="col-description">Опис</th>
                        @if (CanShowPriceColumn)
                        {
                            <th class="price">Вартість, грн</th>
                            <th class="cart-column">Кошик</th>
                        }

                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in _jobs)
                    {
                        <tr>
                            <td data-label="Дата">@job.Date.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            <td data-label="Статус">
                                <span class="status-pill">@job.StatusText</span>
                            </td>
                            <td data-label="Номер" class="mono">@job.Number</td>
                            <td data-label="Замовник">@job.Customer</td>
                            <td data-label="Опис" class="col-description job-description">@job.Description</td>
                            @if (CanShowPriceColumn)
                            {
                                <td data-label="Вартість, грн" class="mono price">
                                    @if (job.IsPayed)
                                    {
                                        <span>СПЛАЧЕНО</span>
                                    }
                                    else if (job.Price > 0)
                                    {

                                        @job.Price
                                    }

                                </td>
                                <td data-label="Кошик" class="cart-column">
                                    @if (job.Price > 0)
                                    {
                                        <button class="cart-toggle @(IsInCart(job) ? "selected" : null)" @onclick="() => ToggleCart(job)">
                                            @(IsInCart(job) ? "Прибрати" : "Додати")
                                        </button>
                                    }

                                </td>
                            }

                        </tr>
                    }
                    @if (CanShowPriceColumn)
                    {
                        <tr>
                            <td data-label="Всього" colspan="6" class=" mono price">
                                <strong>@_totalPrice</strong>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@if (_isCartOpen)
{
    <div class="cart-modal-overlay" @onclick="CloseCart">
        <div class="cart-modal" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="cart-title">
            <div class="cart-modal-header">
                <div>
                    <h2 id="cart-title">Кошик</h2>
                    <p>Додано робіт: @CartCount</p>
                </div>
                <button class="modal-close" @onclick="CloseCart" aria-label="Закрити">×</button>
            </div>

            @if (_cartItems.Count == 0)
            {
                <div class="empty-state compact">
                    <h2>Кошик порожній</h2>
                    <p>Додайте роботи зі списку, щоб побачити їх тут.</p>
                </div>
            }
            else
            {
                <div class="cart-modal-body">
                    <table class="jobs-table cart-table">
                        <thead>
                            <tr>
                                <th>Номер</th>
                                <th>Замовник</th>
                                <th>Опис</th>
                                <th class="price">Вартість, грн</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var job in _cartItems)
                            {
                                <tr>
                                    <td data-label="Номер" class="mono">@job.Number</td>
                                    <td data-label="Замовник">@job.Customer</td>
                                    <td data-label="Опис" class="job-description">@job.Description</td>
                                    <td data-label="Вартість, грн" class="mono price">@job.Price</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <div class="cart-modal-footer">
                <strong>Загальна вартість: @CartTotalPrice грн</strong>
                @if (_currentUser?.PayStatusCode is not null)
                {
                    <button class="primary-action" @onclick="MarkAsPaidAsync" disabled="@(_isUpdatingStatuses || _cartItems.Count == 0)">
                        @(_isUpdatingStatuses ? "Оновлення..." : "Відмітити як сплачене")
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "user")]
    public string? ViewedUsername { get; set; }

    private bool _isLoading = true;
    private string? _loadError;
    private bool _isCartOpen;
    private bool _isUpdatingStatuses;
    private WebUserDefinition? _signedInUser;
    private WebUserDefinition? _currentUser;
    private WebProfileDefinition? _profile;
    private List<JobListItemViewModel> _jobs = new();
    private List<JobListItemViewModel> _cartItems = new();
    private HashSet<string> _cartItemKeys = new(StringComparer.Ordinal);
    private decimal _totalPrice = 0;
    private bool IsAdminViewer => _signedInUser?.IsAdmin == true;
    private bool CanShowPriceColumn => _currentUser?.PayProcesses != null && _currentUser.PayProcesses.Any();
    private int CartCount => _cartItems.Count;
    private decimal CartTotalPrice => _cartItems.Sum(job => job.Price);
    private string PageTitleText => IsAdminViewer
        ? _currentUser is null
            ? "Роботи користувачів"
            : $"Роботи користувача {GetUserDisplayName(_currentUser)} ({_jobs.Count})"
        : $"Список робіт ({_jobs.Count})";
    private string? PageSubtitleText => IsAdminViewer
        ? _currentUser is null
            ? "Адміністратор не має власного списку робіт і переглядає роботи інших користувачів."
            : $"Показані роботи користувача {_currentUser.Username} за його профілем і статусами."
        : null;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var username = authState.User.Identity?.Name;
            _signedInUser = await SettingsStore.FindUserAsync(username);

            if (_signedInUser is null)
            {
                _loadError = "Користувач не знайдений у конфігурації веб-порталу.";
                ResetJobsState(clearSelectedUser: true);
                return;
            }

            if (_signedInUser.IsAdmin)
            {
                if (string.IsNullOrWhiteSpace(ViewedUsername))
                {
                    ResetJobsState(clearSelectedUser: true);
                    return;
                }

                _currentUser = await SettingsStore.FindUserAsync(ViewedUsername);
                if (_currentUser is null)
                {
                    _loadError = $"Користувача '{ViewedUsername}' не знайдено.";
                    ResetJobsState(clearSelectedUser: true);
                    return;
                }

                if (_currentUser.IsAdmin)
                {
                    _loadError = "Адміністратор не має власного списку робіт.";
                    ResetJobsState(clearSelectedUser: true);
                    return;
                }
            }
            else
            {
                _currentUser = _signedInUser;

                if (!_currentUser.CanAccessJobsPage)
                {
                    ResetJobsState();
                    return;
                }
            }

            _profile = await SettingsStore.FindProfileAsync(_currentUser.ProfileKey);
            if (_profile is null)
            {
                _loadError = $"Для користувача '{_currentUser.Username}' не знайдено профіль '{_currentUser.ProfileKey}'.";
                ResetJobsState();
                return;
            }

            _jobs = (await MongoProfileDataService.GetJobsAsync(_profile, _currentUser.VisibleStatusCodes, _currentUser.PayProcesses))
                .ToList();
            _totalPrice = 0;
            if (_jobs.Count > 0)
                _totalPrice = _jobs.Sum(j => j.Price);
            SyncCartWithJobs();
        }
        catch (Exception ex)
        {
            ResetJobsState();
            _loadError = $"Не вдалося завантажити роботи: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ToggleCart(JobListItemViewModel job)
    {
        if (job.Price <= 0)
        {
            return;
        }

        var key = GetCartKey(job);
        if (_cartItemKeys.Add(key))
        {
            _cartItems.Add(job);
            return;
        }

        _cartItemKeys.Remove(key);
        _cartItems.RemoveAll(item => GetCartKey(item) == key);
    }

    private bool IsInCart(JobListItemViewModel job) => _cartItemKeys.Contains(GetCartKey(job));

    private void OpenCart() => _isCartOpen = true;

    private void CloseCart() => _isCartOpen = false;

    private async Task MarkAsPaidAsync()
    {
        if (_isUpdatingStatuses)
            return;

        if (_profile is null || _currentUser?.PayStatusCode is null || _cartItems.Count == 0)
            return;

        _isUpdatingStatuses = true;
        _loadError = null;

        await InvokeAsync(StateHasChanged);

        try
        {
            var profile = _profile;
            var payStatus = _currentUser.PayStatusCode.Value;

            var jobIds = _cartItems
                .Where(j => !string.IsNullOrWhiteSpace(j.Id))
                .Select(j => j.Id!)
                .ToList();

            if (jobIds.Count == 0)
                return;

            await MongoProfileDataService.UpdateJobStatusesAsync(
                profile,
                jobIds,
                payStatus);

            _cartItems.Clear();
            _cartItemKeys.Clear();
            _isCartOpen = false;

            await LoadAsync();
        }
        catch (Exception ex)
        {
            _loadError = $"Не вдалося відмітити роботи як сплачені: {ex.Message}";
        }
        finally
        {
            _isUpdatingStatuses = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void SyncCartWithJobs()
    {
        if (_cartItems.Count == 0)
        {
            return;
        }

        var jobsByKey = _jobs
            .Where(job => job.Price > 0)
            .GroupBy(GetCartKey)
            .ToDictionary(group => group.Key, group => group.First(), StringComparer.Ordinal);

        _cartItems = _cartItemKeys
            .Where(jobsByKey.ContainsKey)
            .Select(key => jobsByKey[key])
            .ToList();

        _cartItemKeys = _cartItems
            .Select(GetCartKey)
            .ToHashSet(StringComparer.Ordinal);

        if (_cartItems.Count == 0)
        {
            _isCartOpen = false;
        }
    }

    private static string GetCartKey(JobListItemViewModel job) =>
        !string.IsNullOrWhiteSpace(job.Id)
            ? job.Id
            : string.Join("|", job.Date.Ticks, job.StatusCode, job.Number, job.Customer, job.Description, job.Price);

    private void ResetJobsState(bool clearSelectedUser = false)
    {
        _jobs.Clear();
        _cartItems.Clear();
        _cartItemKeys.Clear();
        _profile = null;
        _totalPrice = 0;
        _isCartOpen = false;

        if (clearSelectedUser)
        {
            _currentUser = null;
        }
    }

    private static string GetUserDisplayName(WebUserDefinition user) =>
        string.IsNullOrWhiteSpace(user.DisplayName) ? user.Username : user.DisplayName;
}

<style>
    .header-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .cart-button {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.7rem 1rem;
        border: 1px solid rgba(37, 99, 235, 0.2);
        border-radius: 999px;
        background: #eff6ff;
        color: #1d4ed8;
        font-weight: 600;
    }

    .cart-summary {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .cart-button:hover {
        background: #dbeafe;
    }

    .cart-icon {
        font-size: 1.1rem;
    }

    .cart-count {
        min-width: 1.5rem;
        height: 1.5rem;
        padding: 0 0.35rem;
        border-radius: 999px;
        background: #1d4ed8;
        color: #fff;
        font-size: 0.85rem;
        line-height: 1.5rem;
        text-align: center;
    }

    .cart-total {
        color: #0f172a;
        font-weight: 700;
        white-space: nowrap;
    }

    .cart-column {
        width: 8.5rem;
        text-align: center;
    }

    .cart-toggle {
        padding: 0.45rem 0.8rem;
        border: 1px solid #cbd5e1;
        border-radius: 0.75rem;
        background: #fff;
        font-weight: 600;
        color: #0f172a;
    }

        .cart-toggle.selected {
            border-color: #1d4ed8;
            background: #dbeafe;
            color: #1d4ed8;
        }

    .jobs-table tbody tr {
        transition: background-color 0.15s ease;
    }

        .jobs-table tbody tr:hover {
            background: #f8fafc;
        }

    .cart-modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        background: rgba(15, 23, 42, 0.55);
    }

    .cart-modal {
        width: min(900px, 100%);
        max-height: 90vh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        border-radius: 1.25rem;
        background: #fff;
        box-shadow: 0 30px 60px rgba(15, 23, 42, 0.2);
    }

    .cart-modal-header,
    .cart-modal-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid #e2e8f0;
    }

        .cart-modal-header p {
            margin: 0.25rem 0 0;
            color: #475569;
        }

    .cart-modal-footer {
        border-top: 1px solid #e2e8f0;
        border-bottom: 0;
        flex-shrink: 0;
        background: #fff;
    }

    .cart-modal-body {
        flex: 1 1 auto;
        min-height: 0;
        overflow: auto;
        padding: 0 1.5rem 1rem;
    }

    .cart-table {
        margin-top: 1rem;
    }

    .modal-close {
        width: 2.25rem;
        height: 2.25rem;
        border: 0;
        border-radius: 999px;
        background: #e2e8f0;
        color: #0f172a;
        font-size: 1.5rem;
        line-height: 1;
    }

    .empty-state.compact {
        margin: 1.5rem;
    }

    @@media (max-width: 900px) {
        .header-actions {
            width: 100%;
            justify-content: space-between;
            flex-wrap: wrap;
        }

        .cart-column {
            width: auto;
        }

        .cart-summary {
            width: 100%;
            justify-content: space-between;
        }

        .cart-modal {
            width: 100%;
        }
    }
</style>
