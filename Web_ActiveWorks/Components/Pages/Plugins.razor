@page "/plugins"
@attribute [Authorize]
@rendermode InteractiveServer
@inject PluginCatalogService PluginCatalogService

<PageTitle>Плагіни</PageTitle>

<div class="page-header">
    <div>
        <h1>Плагіни ActiveWorks</h1>
        <p class="page-subtitle">Каталог доступних плагінів для встановлення або оновлення у локальному профілі.</p>
    </div>
    <div class="header-actions">
        <button class="primary-action" @onclick="LoadAsync" disabled="@_isLoading">Оновити</button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_loadError))
{
    <div class="alert-panel error-panel">@_loadError</div>
}
else if (_isLoading)
{
    <div class="empty-state">
        <h2>Завантаження</h2>
        <p>Читаю каталог плагінів.</p>
    </div>
}
else if (_plugins.Count == 0)
{
    <div class="empty-state">
        <h2>Плагіни ще не опубліковані</h2>
        <p>Додайте маніфести у каталог публікації плагінів, щоб вони з'явилися на цій сторінці.</p>
    </div>
}
else
{
    <div class="plugin-grid">
        @foreach (var plugin in _plugins)
        {
            <article class="plugin-card">
                <div class="plugin-card-header">
                    <div>
                        <h2>@plugin.Name</h2>
                        <div class="plugin-id">@plugin.Id</div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(plugin.Version))
                    {
                        <span class="version-pill">@plugin.Version</span>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(plugin.Description))
                {
                    <p class="plugin-description">@plugin.Description</p>
                }

                <div class="plugin-meta">
                    <span>Файлів плагіна: @plugin.PluginFilesCount</span>
                    <span>Залежностей: @plugin.DependencyFilesCount</span>
                    <span>@FormatSize(plugin.TotalSize)</span>
                </div>

                @if (!string.IsNullOrWhiteSpace(plugin.Changelog))
                {
                    <div class="plugin-changelog">@plugin.Changelog</div>
                }

                <div class="plugin-actions">
                    <a class="primary-action" href="@GetDownloadHref(plugin.Id)">Завантажити ZIP</a>
                    <a class="secondary-action" href="@GetManifestHref(plugin.Id)">Маніфест</a>
                </div>
            </article>
        }
    </div>
}

@code {
    private bool _isLoading = true;
    private string? _loadError;
    private List<PluginCatalogItem> _plugins = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            _plugins = (await PluginCatalogService.GetCatalogAsync()).ToList();
        }
        catch (Exception ex)
        {
            _plugins.Clear();
            _loadError = "Не вдалося завантажити каталог плагінів: " + ex.Message;
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string GetDownloadHref(string id) => "/api/plugins/" + Uri.EscapeDataString(id) + "/download";

    private static string GetManifestHref(string id) => "/api/plugins/" + Uri.EscapeDataString(id) + "/manifest";

    private static string FormatSize(long bytes)
    {
        if (bytes <= 0)
        {
            return "0 Б";
        }

        string[] units = { "Б", "КБ", "МБ", "ГБ" };
        var size = (double)bytes;
        var unitIndex = 0;
        while (size >= 1024 && unitIndex < units.Length - 1)
        {
            size /= 1024;
            unitIndex++;
        }

        return size.ToString(unitIndex == 0 ? "0" : "0.0") + " " + units[unitIndex];
    }
}

<style>
    .plugin-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1rem;
    }

    .plugin-card {
        display: flex;
        min-height: 15rem;
        flex-direction: column;
        gap: 1rem;
        padding: 1.1rem;
        border: 1px solid #dbe3ef;
        border-radius: 0.5rem;
        background: #fff;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
    }

    .plugin-card-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
    }

    .plugin-card h2 {
        margin: 0;
        color: #0f172a;
        font-size: 1.15rem;
        line-height: 1.25;
    }

    .plugin-id {
        margin-top: 0.25rem;
        color: #64748b;
        font-family: ui-monospace, SFMono-Regular, Consolas, "Liberation Mono", monospace;
        font-size: 0.82rem;
    }

    .version-pill {
        flex-shrink: 0;
        padding: 0.25rem 0.55rem;
        border-radius: 999px;
        background: #ecfdf5;
        color: #047857;
        font-weight: 700;
        font-size: 0.82rem;
    }

    .plugin-description {
        margin: 0;
        color: #334155;
        line-height: 1.45;
    }

    .plugin-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        color: #475569;
        font-size: 0.86rem;
    }

    .plugin-meta span {
        padding: 0.25rem 0.5rem;
        border: 1px solid #e2e8f0;
        border-radius: 999px;
        background: #f8fafc;
    }

    .plugin-changelog {
        padding: 0.75rem;
        border-left: 3px solid #2563eb;
        background: #f8fafc;
        color: #334155;
        white-space: pre-wrap;
    }

    .plugin-actions {
        display: flex;
        gap: 0.65rem;
        margin-top: auto;
        flex-wrap: wrap;
    }

    .plugin-actions a {
        text-decoration: none;
    }

    .secondary-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.5rem;
        padding: 0.65rem 1rem;
        border: 1px solid #cbd5e1;
        border-radius: 0.75rem;
        background: #fff;
        color: #0f172a;
        font-weight: 700;
    }
</style>
